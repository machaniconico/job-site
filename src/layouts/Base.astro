---
import '../styles/tokens.css';
import '../styles/global.css';
import JsonLd from '../components/JsonLd.astro';
import { breadcrumbListJsonLd, type Breadcrumb } from '../lib/breadcrumbs';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  /** OGP/Twitter 画像の絶対URL。省略時は既定の og.png（後方互換）。 */
  ogImage?: string;
  /** パンくず（ホーム→…→現在ページ）。省略時は表示・構造化データとも出力しない。 */
  breadcrumbs?: Breadcrumb[];
}

const {
  title = '性格診断 | Big Five であなたの強みと適職を知る',
  description = 'Big Five（5因子モデル）で性格を測定し、あなたのタイプ・5つの性格特性・性格に合った職業を提案する無料の性格診断。50問・約5分、回答はすべてブラウザ内で完結します。',
  ogImage: ogImageProp,
  breadcrumbs,
} = Astro.props;

const home = withBase('');
const typesHref = withBase('types');
const jobsHref = withBase('jobs');
const aboutHref = withBase('about');
const privacyHref = withBase('privacy');
const ogImage = ogImageProp ?? new URL(withBase('og.png'), Astro.site ?? Astro.url.origin).toString();
const siteUrl = new URL(withBase(''), Astro.site ?? Astro.url.origin).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '性格診断 | Big Five',
  url: siteUrl,
  description,
  inLanguage: 'ja',
};
const crumbs = breadcrumbs ?? [];
const origin = Astro.site ?? Astro.url.origin;
const breadcrumbJsonLd =
  crumbs.length > 0
    ? breadcrumbListJsonLd(
        crumbs.map((crumb) => ({
          name: crumb.name,
          url: new URL(crumb.href, origin).toString(),
        }))
      )
    : null;
const normalizePath = (path: string) => {
  const normalized = path.replace(/\/+$/, '');
  return normalized === '' ? '/' : normalized;
};
const isCurrent = (href: string) => normalizePath(Astro.url.pathname) === normalizePath(href);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const storageKey = 'personality-quiz-theme';
        const root = document.documentElement;

        try {
          const storedTheme = localStorage.getItem(storageKey);
          if (storedTheme === 'dark' || storedTheme === 'light') {
            root.dataset.theme = storedTheme;
          } else {
            root.removeAttribute('data-theme');
          }
        } catch {
          root.removeAttribute('data-theme');
        }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#2563eb" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b1120" />
    <meta name="apple-mobile-web-app-title" content="性格診断" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />
    <link rel="manifest" href={withBase('site.webmanifest')} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="性格診断 | Big Five" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <JsonLd data={jsonLd} />
    {breadcrumbJsonLd && <JsonLd data={breadcrumbJsonLd} />}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>

    <header class="site-header">
      <div class="header-inner">
        <a class="logo" href={home} aria-label="トップページへ">
          <span class="logo-mark" aria-hidden="true">BF</span>
          <span>性格診断</span>
        </a>
        <div class="header-actions">
          <nav class="header-nav" aria-label="サイト内ナビゲーション">
            <a href={home} aria-current={isCurrent(home) ? 'page' : undefined}>診断</a>
            <a href={typesHref} aria-current={isCurrent(typesHref) ? 'page' : undefined}>タイプ一覧</a>
            <a href={jobsHref} aria-current={isCurrent(jobsHref) ? 'page' : undefined}>仕事一覧</a>
            <a href={aboutHref} aria-current={isCurrent(aboutHref) ? 'page' : undefined}>このサイトについて</a>
            <a href={privacyHref} aria-current={isCurrent(privacyHref) ? 'page' : undefined}>プライバシー</a>
          </nav>
          <button class="theme-toggle" type="button" data-theme-toggle aria-label="ダークモードに切り替え" aria-pressed="false">
            <span class="theme-toggle-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </header>

    <main id="main">
      {
        crumbs.length > 0 && (
          <nav class="breadcrumb" aria-label="パンくずリスト">
            <div class="container">
              <ol>
                {crumbs.map((crumb, index) => (
                  <li>
                    {index < crumbs.length - 1 ? (
                      <a href={crumb.href}>{crumb.name}</a>
                    ) : (
                      <span aria-current="page">{crumb.name}</span>
                    )}
                  </li>
                ))}
              </ol>
            </div>
          </nav>
        )
      }
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>性格診断 — Big Five をもとにした自己理解のためのサンプル診断。</span>
        <nav class="header-nav" aria-label="フッターナビゲーション">
          <a href={typesHref} aria-current={isCurrent(typesHref) ? 'page' : undefined}>タイプ一覧</a>
          <a href={jobsHref} aria-current={isCurrent(jobsHref) ? 'page' : undefined}>仕事一覧</a>
          <a href={aboutHref} aria-current={isCurrent(aboutHref) ? 'page' : undefined}>このサイトについて</a>
          <a href={privacyHref} aria-current={isCurrent(privacyHref) ? 'page' : undefined}>プライバシー</a>
        </nav>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const storageKey = 'personality-quiz-theme';
        const root = document.documentElement;
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const toggles = document.querySelectorAll('[data-theme-toggle]');

        const effectiveTheme = () => {
          if (root.dataset.theme === 'dark' || root.dataset.theme === 'light') {
            return root.dataset.theme;
          }
          return media.matches ? 'dark' : 'light';
        };

        const syncToggles = () => {
          const isDark = effectiveTheme() === 'dark';
          const label = isDark ? 'ライトモードに切り替え' : 'ダークモードに切り替え';
          toggles.forEach((toggle) => {
            toggle.setAttribute('aria-label', label);
            toggle.setAttribute('aria-pressed', String(isDark));
            toggle.setAttribute('title', label);
          });
        };

        toggles.forEach((toggle) => {
          toggle.addEventListener('click', () => {
            const nextTheme = effectiveTheme() === 'dark' ? 'light' : 'dark';
            root.dataset.theme = nextTheme;

            try {
              localStorage.setItem(storageKey, nextTheme);
            } catch {
              /* Theme still applies for this page view if storage is unavailable. */
            }

            syncToggles();
          });
        });

        media.addEventListener('change', syncToggles);
        syncToggles();
      })();
    </script>
  </body>
</html>
