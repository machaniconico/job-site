---
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '性格診断 | Big Five であなたの強みと適職を知る',
  description = 'Big Five（5因子モデル）で性格を測定し、あなたのタイプ・5つの性格特性・性格に合った職業を提案する無料の性格診断。50問・約5分、回答はすべてブラウザ内で完結します。',
} = Astro.props;

const base = import.meta.env.BASE_URL;
// 末尾スラッシュを正規化して内部リンクを組み立てる
const withBase = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const home = withBase('');
const aboutHref = withBase('about');
const privacyHref = withBase('privacy');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>

    <header class="site-header">
      <div class="header-inner">
        <a class="logo" href={home} aria-label="トップページへ">
          <span class="logo-mark" aria-hidden="true">BF</span>
          <span>性格診断</span>
        </a>
        <nav class="header-nav" aria-label="サイト内ナビゲーション">
          <a href={home}>診断</a>
          <a href={aboutHref}>このサイトについて</a>
          <a href={privacyHref}>プライバシー</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>性格診断 — Big Five をもとにした自己理解のためのサンプル診断。</span>
        <nav class="header-nav" aria-label="フッターナビゲーション">
          <a href={aboutHref}>このサイトについて</a>
          <a href={privacyHref}>プライバシー</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
