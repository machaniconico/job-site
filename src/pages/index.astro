---
import Base from '../layouts/Base.astro';
import { FACTORS, FACTOR_DISPLAY_ORDER } from '../data/dimensions';
import { QUESTION_COUNT } from '../data/questions';
import { OCCUPATIONS } from '../data/occupations';
import { PERSONALITY_TYPES } from '../data/personalityTypes';

// 内部リンクは Base.astro に倣ってローカルに組み立てる（末尾スラッシュを正規化）。
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const typesHref = withBase('types');
const jobsHref = withBase('jobs');

// 「診断でわかること」プレビューのカード（件数はデータ駆動で陳腐化させない）。
const previewCards = [
  {
    icon: '✨',
    title: 'あなたの性格タイプ',
    body: `${PERSONALITY_TYPES.length}種の代表タイプ＋バランス型から、いちばん近いものを言葉にして返します。`,
  },
  {
    icon: '🧭',
    title: '5つの性格因子スコア',
    body: 'Big Five の5因子を0〜100で見える化。レーダーチャートで全体の傾向をつかめます。',
  },
  {
    icon: '💼',
    title: '性格に合いやすい仕事',
    body: `${OCCUPATIONS.length}職業の中から、あなたの傾向と近いものを相対的に並べて提示します。`,
  },
  {
    icon: '🔍',
    title: '近いタイプとファセット内訳',
    body: '次に近いタイプや、各因子の下位ファセットの内訳まで掘り下げて確認できます。',
  },
];
---

<Base>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">やさしい Big Five 性格診断</p>
        <h1>あなたの性格を測って、<br /><span class="hero-title-accent">強みと向いてる仕事</span>まで。</h1>
        <p class="lead">
          心理学で最も広く使われる Big Five（5因子）で性格を測定。{QUESTION_COUNT}問・約5分で、あなたのタイプ・5つの性格特性・性格に合った職業を提案します。途中でやめても大丈夫。回答はこの端末の中だけに保存されます。
        </p>
        <div class="hero-actions">
          <button class="btn btn-primary" id="startBtn" type="button">さっそく始める（{QUESTION_COUNT}問・約5分）</button>
          <button class="btn btn-secondary" id="resumeBtn" type="button" hidden>続きから</button>
          <button class="btn btn-ghost" id="resetBtn" type="button" hidden>回答をリセット</button>
        </div>
        <div class="notice-box" role="note">
          <strong>注意:</strong> 自己理解のための簡易診断です。医療・心理判定・採用選考の根拠には使えません。
        </div>
      </div>
      <aside class="stat-card" aria-label="診断の概要">
        <p class="eyebrow">この診断について</p>
        <div class="stat-grid">
          <div><span class="stat-value"><span class="stat-icon" aria-hidden="true">📝</span><strong>{QUESTION_COUNT}</strong></span><span>設問</span></div>
          <div><span class="stat-value"><span class="stat-icon" aria-hidden="true">🧭</span><strong>5</strong></span><span>性格因子</span></div>
          <div><span class="stat-value"><span class="stat-icon" aria-hidden="true">✨</span><strong>{PERSONALITY_TYPES.length}</strong></span><span>タイプ</span></div>
          <div><span class="stat-value"><span class="stat-icon" aria-hidden="true">💼</span><strong>{OCCUPATIONS.length}</strong></span><span>職業候補</span></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">診断でわかること</p>
      <h2>答え終えると、こんなことが見えてきます</h2>
      <p class="lead">
        当たり外れを決めつけるものではなく、自分を言葉にして見つめ直すきっかけとして使ってください。
      </p>
      <ul class="preview-grid">
        {
          previewCards.map((card) => (
            <li class="preview-card">
              <span class="preview-icon" aria-hidden="true">{card.icon}</span>
              <h3 class="preview-title">{card.title}</h3>
              <p class="preview-body">{card.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="explore-panel">
        <div class="explore-text">
          <p class="eyebrow">先に眺めてみる</p>
          <h2>診断しなくても、タイプと仕事は見られます</h2>
          <p>
            どんなタイプや職業があるのか気になったら、一覧から先にのぞいてみてください。診断は気が向いたときで大丈夫です。
          </p>
        </div>
        <div class="explore-actions">
          <a class="btn btn-primary" href={typesHref}>タイプを見る（{PERSONALITY_TYPES.length}種）</a>
          <a class="btn btn-secondary" href={jobsHref}>仕事を見る（{OCCUPATIONS.length}職業）</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="methodology">
    <div class="container">
      <p class="eyebrow">診断のしくみ</p>
      <h2>5つの性格因子（Big Five）</h2>
      <p class="lead">
        人の性格は、次の5つの大きな factor で説明できるとされています。各 factor を10問ずつ、逆転項目を入れて測ります。
      </p>
      <ul class="axis-list">
        {
          FACTOR_DISPLAY_ORDER.map((k) => (
            <li>
              <strong>
                {FACTORS[k].displayLabel}（{FACTORS[k].englishName}）
              </strong>
              <span>{FACTORS[k].description}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" id="diagnosis" hidden>
    <div class="container">
      <div class="panel">
        <p class="eyebrow">質問タイム</p>
        <h2 id="pageTitle">診断</h2>
        <div class="progress-shell" aria-label="回答の進捗">
          <div class="progress-track" aria-hidden="true"><span class="progress-bar" id="progressBar"></span></div>
          <div class="progress-texts">
            <span id="progressText">0 / {QUESTION_COUNT} 問</span>
            <span id="encourageText"></span>
            <span id="pageText"></span>
          </div>
        </div>
        <div class="question-list" id="questionList"></div>
        <p class="page-hint" id="pageHint" role="status" aria-live="polite"></p>
        <div class="question-actions">
          <button class="btn btn-ghost" id="prevBtn" type="button">前へ</button>
          <button class="btn btn-ghost" id="jumpUnansweredBtn" type="button" hidden>未回答へ移動 ↓</button>
          <span class="spacer"></span>
          <button class="btn btn-primary" id="nextBtn" type="button">次へ</button>
          <button class="btn btn-primary" id="finishBtn" type="button" hidden>結果を見る</button>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="result" hidden>
    <div class="container">
      <article class="panel">
        <p class="eyebrow">あなたの結果</p>
        <p class="result-greeting">お疲れさま！じっくり答えてくれてありがとう <span aria-hidden="true">🎉</span> あなたの結果はこちら。</p>
        <div id="typeHero"></div>
      </article>
      <div id="nearbyTypes"></div>
      <article class="panel" style="margin-top: var(--space-5)">
        <h2>5つの性格スコア</h2>
        <div class="factor-chart" id="factorChart"></div>
        <div class="bars" id="factorBars"></div>
        <p id="factorNote" style="font-size: var(--step--1); color: var(--color-text-mute); margin-top: var(--space-4)"></p>
      </article>
      <article class="panel" style="margin-top: var(--space-5)">
        <p class="eyebrow">あなたに合いそうな仕事</p>
        <h2>性格に合う仕事</h2>
        <p>
          あなたの5因子プロファイルと、各職業に向いた人の傾向との「近さ」で並べた相対的な候補です。資格・求人・収入・経験などは別途ご確認ください。
        </p>
        <div class="job-list" id="jobList"></div>
      </article>
      <div class="result-actions">
        <button class="btn btn-secondary" id="shareBtn" type="button">結果をXでシェア</button>
        <button class="btn btn-secondary" id="saveImageBtn" type="button">画像で保存</button>
        <button class="btn btn-ghost" id="copyBtn" type="button">要約をコピー</button>
        <button class="btn btn-ghost" id="jsonBtn" type="button">結果JSONを保存</button>
        <button class="btn btn-ghost" id="printBtn" type="button">印刷 / PDF</button>
        <button class="btn btn-ghost" id="retakeBtn" type="button">もう一度</button>
      </div>
    </div>
  </section>

  <script>
    import '../scripts/app.ts';
  </script>
</Base>
