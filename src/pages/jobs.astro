---
import Base from '../layouts/Base.astro';
import JsonLd from '../components/JsonLd.astro';
import { OCCUPATIONS } from '../data/occupations';
import type { Occupation } from '../lib/types';
import { itemListJsonLd } from '../lib/itemList';
import { withBase } from '../lib/url';

const home = withBase('');

// category ごとにグルーピング（初出順を保つ）。
const groups: { category: string; jobs: Occupation[] }[] = [];
for (const occupation of OCCUPATIONS) {
  let group = groups.find((g) => g.category === occupation.category);
  if (!group) {
    group = { category: occupation.category, jobs: [] };
    groups.push(group);
  }
  group.jobs.push(occupation);
}

// クライアント検索用の正規化済みインデックス文字列（職業名 + 説明 + スキル + カテゴリ）。
// jobSearch.ts の normalize() と同じ規則（全角空白→半角・小文字化）で生成する。
const searchIndex = (job: Occupation): string =>
  [job.title, job.description, job.skillThemes.join(' '), job.category]
    .join(' ')
    .replace(/　/g, ' ')
    .toLowerCase();

// チップ表示用のカテゴリ一覧（初出順）。
const categories = groups.map((g) => g.category);

const title = '職業一覧 | 性格診断';
const description = `性格診断で提案する全${OCCUPATIONS.length}職業の一覧。エンジニアリングからクリエイティブ、医療・福祉まで、カテゴリ別に仕事内容を一覧できます。気になる職業から、活躍する人の傾向を読んでみてください。`;

const breadcrumbs = [
  { name: 'ホーム', href: home },
  { name: '仕事一覧', href: withBase('jobs/') },
];

// 一覧カードと同じ並び順（カテゴリ別の初出順）で ItemList 構造化データを宣言。
const origin = Astro.site ?? Astro.url.origin;
const listJsonLd = itemListJsonLd(
  groups.flatMap((group) =>
    group.jobs.map((job) => ({
      name: job.title,
      url: new URL(withBase(`job/${job.id}/`), origin).toString(),
    })),
  ),
);
---

<Base title={title} description={description} breadcrumbs={breadcrumbs}>
  <JsonLd data={listJsonLd} slot="head" />
  <section class="section">
    <div class="container">
      <article class="panel">
        <p class="eyebrow">職業一覧</p>
        <h1>{OCCUPATIONS.length}の職業ガイド</h1>
        <p class="lead">
          性格診断が性格プロファイルから提案する職業の一覧です。カテゴリ別に並べています。気になる職業を選んで、仕事内容と活躍する人のBig Five傾向を読んでみてください。
        </p>
        <p class="job-detail-note" style="margin-top: var(--space-3)">
          あなたに合った職業は、50問・約5分の診断で性格に合わせて提案されます。
        </p>
        <div class="hero-actions" style="margin-top: var(--space-4)">
          <a class="btn btn-primary" href={home}>診断をはじめる</a>
        </div>
      </article>

      <article class="panel job-search" data-job-search hidden style="margin-top: var(--space-5)">
        <label class="sr-only" for="job-search-input">職業を検索</label>
        <input
          id="job-search-input"
          class="job-search-input"
          type="search"
          inputmode="search"
          autocomplete="off"
          placeholder="職業名・仕事内容・スキルで検索（例: デザイン / データ / 医療）"
        />
        <div class="job-filter-chips" role="group" aria-label="カテゴリで絞り込み">
          <button type="button" class="chip" data-category-chip="" aria-pressed="true">すべて</button>
          {categories.map((category) => (
            <button type="button" class="chip" data-category-chip={category} aria-pressed="false">
              {category}
            </button>
          ))}
        </div>
        <p class="job-search-count" id="job-search-count" role="status" aria-live="polite">
          {OCCUPATIONS.length}件の職業
        </p>
        <p class="job-search-empty" id="job-search-empty" hidden>
          該当する職業が見つかりませんでした。別のキーワードやカテゴリでお試しください。
        </p>
      </article>

      {
        groups.map((group) => (
          <article class="panel job-group" data-job-group data-category={group.category} style="margin-top: var(--space-5)">
            <p class="eyebrow">{group.category}</p>
            <div class="job-grid">
              {group.jobs.map((job) => (
                <a
                  class="job-grid-card"
                  href={withBase(`job/${job.id}/`)}
                  data-search={searchIndex(job)}
                  data-category={job.category}
                >
                  <span class="job-grid-title">{job.title}</span>
                  <span class="job-grid-desc">{job.description}</span>
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
  <script>
    import '../scripts/jobSearch.ts';
  </script>
</Base>
